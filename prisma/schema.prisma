generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int     @id @default(autoincrement())
  username  String  @unique
  password  String
  machineries Machinery[]
}

model Machinery {
  id         Int     @id @default(autoincrement())
  name       String
  type       String
  available  Boolean
  rentPrice  Int
  description String?
  imageUrl   String?
  ownerId    Int?
  owner      User?   @relation(fields: [ownerId], references: [id])
}
